generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  AM
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(AM)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  accounts     Account[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Grafana Datasources ──────────────────────────────────────────────────────

enum DatasourceType {
  LOKI
  ELASTICSEARCH
}

model GrafanaDatasource {
  id        String         @id @default(cuid())
  name      String         @unique
  type      DatasourceType
  baseUrl   String
  apiKey    String
  lokiOrgId String?
  esIndex   String?
  esUsername String?
  esPassword String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  appEnvConfigs AppEnvConfig[]
}

// ─── Applications & Environments ─────────────────────────────────────────────

model Application {
  id            String         @id @default(cuid())
  name          String         @unique
  displayName   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appEnvConfigs AppEnvConfig[]
}

model Environment {
  id            String         @id @default(cuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appEnvConfigs AppEnvConfig[]
}

// ─── App × Env Configuration ──────────────────────────────────────────────────

model AppEnvConfig {
  id            String            @id @default(cuid())
  applicationId String
  environmentId String
  datasourceId  String
  queryTemplate String            @db.Text
  lookbackHours Int               @default(24)
  enabled       Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  application  Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  environment  Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  datasource   GrafanaDatasource @relation(fields: [datasourceId], references: [id])

  dailyReports DailyReport[]
  errorEntries ErrorEntry[]

  @@unique([applicationId, environmentId])
}

// ─── Error Fingerprints & Reports ────────────────────────────────────────────

model ErrorEntry {
  id             String       @id @default(cuid())
  appEnvConfigId String
  fingerprint    String
  normalizedMsg  String       @db.Text
  exampleRawMsg  String       @db.Text
  firstSeenAt    DateTime
  lastSeenAt     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  appEnvConfig  AppEnvConfig  @relation(fields: [appEnvConfigId], references: [id], onDelete: Cascade)
  reportEntries ReportEntry[]

  @@unique([appEnvConfigId, fingerprint])
  @@index([fingerprint])
}

enum ReportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model DailyReport {
  id             String       @id @default(cuid())
  appEnvConfigId String
  reportDate     DateTime
  generatedAt    DateTime     @default(now())
  status         ReportStatus @default(PENDING)
  errorCount     Int          @default(0)
  uniqueErrors   Int          @default(0)
  newErrors      Int          @default(0)
  pdfStoragePath String?
  emailSentAt    DateTime?
  errorMessage   String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  appEnvConfig  AppEnvConfig  @relation(fields: [appEnvConfigId], references: [id], onDelete: Cascade)
  reportEntries ReportEntry[]

  @@unique([appEnvConfigId, reportDate])
  @@index([reportDate])
}

model ReportEntry {
  id            String      @id @default(cuid())
  reportId      String
  errorEntryId  String
  countInWindow Int
  isNew         Boolean
  aiHint        String?     @db.Text

  report     DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  errorEntry ErrorEntry  @relation(fields: [errorEntryId], references: [id])

  @@unique([reportId, errorEntryId])
}

// ─── Email & Schedule Config ──────────────────────────────────────────────────

model EmailConfig {
  id          String   @id @default(cuid())
  host        String
  port        Int      @default(587)
  secure      Boolean  @default(false)
  user        String
  password    String
  fromAddress String
  recipients  String   @db.Text
  updatedAt   DateTime @updatedAt
}

model ScheduleConfig {
  id       String   @id @default(cuid())
  cronExpr String   @default("0 6 * * *")
  enabled  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
